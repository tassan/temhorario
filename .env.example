# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL (use o mesmo host/porta do docker-compose em dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/temhorario_engine
DATABASE_POOL_SIZE=20

# Redis (opcional até rate limit / cache)
# REDIS_URL=redis://localhost:6379

# Auth — gerar segredo forte em produção (mín. 32 caracteres)
JWT_SECRET=change-me-use-at-least-32-characters!!
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Webhooks (opcional nas primeiras fases)
# WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3
