# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL (mesmo host/porta que em `docker-compose.yml` — no repo o host usa 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/temhorario_engine
# Opcional: só para `npm run db:migrate` — ver `.env.docker` e `npm run db:migrate:docker`
# MIGRATE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/temhorario_engine?sslmode=disable
DATABASE_POOL_SIZE=20

# Redis (opcional — rate limit usa memória in-process se omitido)
# REDIS_URL=redis://localhost:6379

# Rate limiting (req/min por janela de 60s)
RATE_LIMIT_PUBLIC_PER_MINUTE=60
RATE_LIMIT_ADMIN_PER_MINUTE=300

# Auth — gerar segredo forte em produção (mín. 32 caracteres)
JWT_SECRET=change-me-use-at-least-32-characters!!
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Webhooks (opcional nas primeiras fases)
# WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3
