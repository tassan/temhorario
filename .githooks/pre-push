#!/bin/sh
# pre-push: exige que CHANGELOG.md figure entre os ficheiros alterados no intervalo a enviar.
# Isto alinha-se a docs/git/keep-changelog.md e docs/git/git-strategy.md.
#
# Contorno excecional (não usar em rotina):
#   SKIP_CHANGELOG_HOOK=1 git push ...
#
# Requer: git fetch origin (para origin/main) antes do primeiro push de branch nova.

if [ -n "${SKIP_CHANGELOG_HOOK:-}" ]; then
  exit 0
fi

# Argumentos do git: $1 = remote, $2 = url (não usados pelo hook)

ZERO=0000000000000000000000000000000000000000
EMPTY_TREE=4b825dc642cb6eb9a060e54bf8d69288fbee4904

failed=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${local_ref:-}" ] && continue

  # Eliminação de branch remota
  if [ "$local_sha" = "$ZERO" ]; then
    continue
  fi

  # Só branches (não tags); pushes de tags não passam por esta regra
  case "$remote_ref" in
    refs/heads/*) ;;
    *) continue ;;
  esac

  if [ "$remote_sha" = "$ZERO" ]; then
    # Branch nova no remoto: diff desde merge-base com trunk remoto
    base=""
    if git rev-parse --verify refs/remotes/origin/main >/dev/null 2>&1; then
      base=$(git merge-base origin/main "$local_sha" 2>/dev/null) || base=""
    elif git rev-parse --verify refs/remotes/origin/master >/dev/null 2>&1; then
      base=$(git merge-base origin/master "$local_sha" 2>/dev/null) || base=""
    fi

    if [ -n "$base" ]; then
      old="$base"
    else
      first_parent=$(git rev-parse "$local_sha^" 2>/dev/null) || first_parent=""
      if [ -n "$first_parent" ]; then
        old="$first_parent"
      else
        old="$EMPTY_TREE"
      fi
    fi
    files=$(git diff --name-only "$old" "$local_sha" 2>/dev/null || true)
  else
    files=$(git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null || true)
  fi

  # Nada a enviar para esta ref
  if [ -z "$files" ]; then
    continue
  fi

  if ! echo "$files" | grep -Fxq 'CHANGELOG.md'; then
    echo "pre-push: bloqueado — o conjunto de alterações a enviar inclui outros ficheiros mas não CHANGELOG.md." >&2
    echo "pre-push: atualize CHANGELOG.md (ver docs/git/keep-changelog.md). Para emergências: SKIP_CHANGELOG_HOOK=1 git push ..." >&2
    failed=1
  fi
done

exit "$failed"
