{
  "name": "temhorario-engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "node scripts/setup-hooks.mjs",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:generate:docker": "node --env-file=.env.docker ./node_modules/tsx/dist/cli.mjs node_modules/drizzle-kit/bin.cjs generate",
    "db:ensure": "tsx scripts/ensure-postgres-docker.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:docker": "npm run db:ensure && cross-env \"MIGRATE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/temhorario_engine?sslmode=disable\" node ./node_modules/tsx/dist/cli.mjs scripts/migrate.ts",
    "db:migrate:test:docker": "npm run db:ensure && cross-env \"MIGRATE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/temhorario_test?sslmode=disable\" node ./node_modules/tsx/dist/cli.mjs scripts/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:docker": "npm run db:ensure && node --env-file=.env.docker ./node_modules/tsx/dist/cli.mjs src/db/seed.ts",
    "db:studio": "tsx node_modules/drizzle-kit/bin.cjs studio",
    "db:studio:docker": "node --env-file=.env.docker ./node_modules/tsx/dist/cli.mjs node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "bcrypt": "^6.0.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
